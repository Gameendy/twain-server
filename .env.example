# Port (Render sets this automatically)
PORT=4000

# Secret the website uses to POST tokens to this server
WEBSITE_SECRET=change-this-to-a-long-random-string

# Secret to access the admin panel
ADMIN_SECRET=change-this-to-another-long-random-string

# Allowed origins (comma-separated) — add your Vercel URL
ALLOWED_ORIGINS=http://localhost:3000,https://twain-website.vercel.app
